{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiom.local/schemas/estimate_data_source.schema.json",
  "title": "AXIOM Estimate Data Source",
  "type": "object",
  "required": ["schema_version", "provider_id", "provider_name", "as_of_date", "provenance", "estimates", "forward_assumptions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "provider_id": {"type": "string", "pattern": "^provider:"},
    "provider_name": {"type": "string", "minLength": 1},
    "as_of_date": {"type": "string", "format": "date"},
    "provenance": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "estimates": {"type": "array", "items": {"type": "object"}},
    "forward_assumptions": {"type": "array", "items": {"type": "object"}}
  }
}
