{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axiom.local/schemas/sec-companyfacts.schema.json",
  "title": "SEC XBRL Company Facts Snapshot",
  "type": "object",
  "required": ["cik", "entityName", "facts"],
  "properties": {
    "cik": {"type": ["integer", "string"]},
    "entityName": {"type": "string", "minLength": 1},
    "facts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "required": ["label", "description", "units"],
          "properties": {
            "label": {"type": "string"},
            "description": {"type": "string"},
            "units": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["val"],
                  "properties": {
                    "val": {"type": ["number", "string"]},
                    "accn": {"type": "string"},
                    "fy": {"type": "integer"},
                    "fp": {"type": "string"},
                    "form": {"type": "string"},
                    "filed": {"type": "string"},
                    "start": {"type": "string"},
                    "end": {"type": "string"},
                    "frame": {"type": "string"}
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "additionalProperties": true
}
